{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2023",
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src", "prisma", "api", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
