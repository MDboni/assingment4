# ---------- App ----------
NODE_ENV=development
PORT=5000
# CORS origin (frontend URL)
APP_URL=http://localhost:3000

# ---------- Database ----------
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/rentnest?schema=public

# ---------- Auth ----------
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
# local: `stripe listen --forward-to localhost:5000/api/payments/confirm` থেকে পাওয়া whsec_
# production: Stripe Dashboard > Developers > Webhooks থেকে
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_SUCCESS_URL=http://localhost:5000/payment/success
STRIPE_CANCEL_URL=http://localhost:5000/payment/cancel
# Stripe BDT 
PAYMENT_CURRENCY=USD
